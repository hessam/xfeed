# Core domain and DNS behavior
THEFEED_DOMAIN=t.example.com
DNS_PADDING_MIN=12
DNS_PADDING_MAX=56

# Encryption and auth
# NEVER commit real secrets. Populate these in deploy/.env on VPS.
THEFEED_MASTER_KEY=replace-with-32-byte-base64-or-hex
TOKEN_HMAC_SECRET=replace-with-long-random-secret
AUTH_ADMIN_SECRET=replace-with-admin-api-secret
TOKEN_TTL_DAYS=30
AUTH_RATE_LIMIT_RPS=5

# Frontend -> auth exchange target
AUTH_PUBLIC_BASE_URL=https://auth.example.com
